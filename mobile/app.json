{
  "expo": {
    "name": "WorkoutMoneyApp",
    "slug": "workoutmoneyapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0d1117",
    "splash": {
      "backgroundColor": "#0d1117",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "The camera verifies your workout while you count reps."
      }
    },
    "android": {
      "permissions": ["CAMERA"]
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "The camera verifies your workout while you count reps."
        }
      ]
    ]
  }
}
