rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // A user can READ only their own data.
    // NOBODY can write from the client — every write goes through a Cloud
    // Function (which runs as admin and bypasses these rules). This is what
    // makes the contract, workout log, and forfeit totals tamper-proof:
    // clearing the browser or editing localStorage can't change the truth.
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;

      match /log/{dateKey} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if false;
      }
      match /charges/{chargeId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if false;
      }
    }
  }
}
